# Copy to .env and fill in CNX_API_KEY. The .env file is gitignored.
#
# Auth: an Application Key (Admin Portal -> Settings -> System -> Application API Keys).
# It is sent as the header:  Authorization: ApplicationKey <key>
# The scheme word "ApplicationKey" matters — it is NOT "Bearer".

CNX_ROOT_URI=https://sisclientweb-test-100910.campusnexus.cloud/

# "apikey" (default) or "basic"
CNX_AUTH_MODE=apikey

# Paste your Application Key here (Base64 JSON blob). Leave the scheme as-is.
CNX_API_KEY=
CNX_API_KEY_SCHEME=ApplicationKey

# Only used when CNX_AUTH_MODE=basic
CNX_USERNAME=
CNX_PASSWORD=

# Entity-set paths (defaults are correct for the Query API)
CNX_SECTIONS_PATH=ds/odata/ClassSectionTerms
CNX_TERMS_PATH=ds/odata/Terms

# Per-request timeout (seconds)
CNX_TIMEOUT=30
